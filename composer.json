{
    "name": "marko/errors-simple",
    "description": "Simple error handling and display for the Marko framework",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "marko/core": "^0.1",
        "marko/errors": "^0.1"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\ErrorsSimple\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\ErrorsSimple\\Tests\\": "tests/"
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
